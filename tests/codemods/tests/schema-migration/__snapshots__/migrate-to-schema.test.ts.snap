  'name': 'timestampable',
  'mode': 'legacy',
  'fields': [
    {
      'name': 'createdAt',
      'kind': 'attribute',
      'type': 'date'
    },
    {
      'name': 'updatedAt',
      'kind': 'attribute',
      'type': 'date'
    }
  ],
  'traits': [
    'deleteable'
  ]
} satisfies LegacyTrait;

export default TimestampableTraitSchema;
",
  "traits/timestampable.type.ts": "
